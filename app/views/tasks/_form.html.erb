<%= form_with model: task, local: true, class: "row g-3" do |form| %>
  <% if task.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger">
        <h6>Please fix the following errors:</h6>
        <ul class="mb-0">
          <% task.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="col-12">
    <%= form.label :title, class: "form-label" %>
    <%= form.text_field :title, class: "form-control #{'is-invalid' if task.errors[:title].any?}", 
                        placeholder: "Enter task title", maxlength: 255 %>
    <% if task.errors[:title].any? %>
      <div class="invalid-feedback">
        <%= task.errors[:title].first %>
      </div>
    <% end %>
  </div>

  <div class="col-12">
    <%= form.label :description, class: "form-label" %>
    <%= form.text_area :description, class: "form-control", rows: 4,
                       placeholder: "Enter task description (optional)" %>
    <div class="form-text">Optional: Provide more details about this task.</div>
  </div>

  <% unless task.new_record? %>
    <div class="col-12">
      <div class="form-check">
        <%= form.check_box :completed, class: "form-check-input" %>
        <%= form.label :completed, "Mark as completed", class: "form-check-label" %>
      </div>
    </div>
  <% end %>

  <div class="col-12">
    <div class="d-flex gap-2">
      <%= form.submit task.new_record? ? "Create Task" : "Update Task", 
                      class: "btn btn-success" %>
      <%= link_to "Cancel", task.new_record? ? root_path : task_path(task), 
                  class: "btn btn-secondary" %>
    </div>
  </div>
<% end %>