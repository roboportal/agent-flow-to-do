<div class="mb-3">
  <%= link_to "← Back to Tasks", root_path, class: "btn btn-secondary" %>
</div>

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h2 class="mb-0 <%= 'text-decoration-line-through text-muted' if @task.completed %>">
      <%= @task.title %>
    </h2>
    <% if @task.completed %>
      <span class="badge bg-success fs-6">Completed</span>
    <% else %>
      <span class="badge bg-warning fs-6">Pending</span>
    <% end %>
  </div>
  
  <div class="card-body">
    <% if @task.description.present? %>
      <h6>Description:</h6>
      <p class="mb-4"><%= simple_format(@task.description) %></p>
    <% else %>
      <p class="text-muted fst-italic mb-4">No description provided.</p>
    <% end %>
    
    <div class="row">
      <div class="col-sm-6">
        <strong>Created:</strong> <%= @task.created_at.strftime("%B %d, %Y at %I:%M %p") %>
      </div>
      <div class="col-sm-6">
        <strong>Last Updated:</strong> <%= @task.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
      </div>
    </div>
  </div>
  
  <div class="card-footer bg-transparent">
    <div class="d-flex gap-2 flex-wrap">
      <%= link_to "Edit Task", edit_task_path(@task), class: "btn btn-primary" %>
      
      <% if @task.completed %>
        <%= form_with model: @task, local: true, class: "d-inline" do |form| %>
          <%= form.hidden_field :completed, value: false %>
          <%= form.submit "Mark as Pending", class: "btn btn-warning" %>
        <% end %>
      <% else %>
        <%= form_with model: @task, local: true, class: "d-inline" do |form| %>
          <%= form.hidden_field :completed, value: true %>
          <%= form.submit "Mark as Complete", class: "btn btn-success" %>
        <% end %>
      <% end %>
      
      <%= link_to "Delete Task", task_path(@task), method: :delete,
                  confirm: "Are you sure you want to delete this task? This cannot be undone.",
                  class: "btn btn-danger" %>
    </div>
  </div>
</div>