<% content_for :title, @task.title %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%= @task.title %></h1>
  <span class="badge fs-6 <%= @task.completed? ? 'bg-success' : 'bg-warning' %>">
    <%= @task.completed? ? 'Completed' : 'Pending' %>
  </span>
</div>

<div class="card">
  <div class="card-body">
    <% if @task.description.present? %>
      <h5 class="card-title">Description</h5>
      <p class="card-text"><%= simple_format(@task.description) %></p>
    <% else %>
      <p class="text-muted">No description provided.</p>
    <% end %>
    
    <hr>
    
    <div class="row">
      <div class="col-sm-6">
        <p><strong>Created:</strong> <%= @task.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
      </div>
      <div class="col-sm-6">
        <p><strong>Last Updated:</strong> <%= @task.updated_at.strftime("%B %d, %Y at %I:%M %p") %></p>
      </div>
    </div>
  </div>
</div>

<div class="mt-3">
  <%= link_to "Edit Task", edit_task_path(@task), class: "btn btn-primary" %>
  <%= button_to "Delete Task", task_path(@task), method: :delete, 
                class: "btn btn-danger",
                data: { confirm: 'Are you sure you want to delete this task?' } %>
  <%= link_to "Back to Tasks", tasks_path, class: "btn btn-secondary" %>
</div>