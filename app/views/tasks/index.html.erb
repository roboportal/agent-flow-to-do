<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>My Tasks</h1>
  <%= link_to "New Task", new_task_path, class: "btn btn-success" %>
</div>

<div class="mb-4">
  <div class="btn-group" role="group" aria-label="Filter tasks">
    <%= link_to "All", root_path, 
        class: "btn #{'btn-primary' if @filter == 'all'} #{'btn-outline-primary' if @filter != 'all'}" %>
    <%= link_to "Pending", root_path(filter: 'pending'), 
        class: "btn #{'btn-primary' if @filter == 'pending'} #{'btn-outline-primary' if @filter != 'pending'}" %>
    <%= link_to "Completed", root_path(filter: 'completed'), 
        class: "btn #{'btn-primary' if @filter == 'completed'} #{'btn-outline-primary' if @filter != 'completed'}" %>
  </div>
</div>

<% if @tasks.any? %>
  <div class="row">
    <% @tasks.each do |task| %>
      <div class="col-md-6 col-lg-4 mb-3">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h5 class="card-title <%= 'text-decoration-line-through text-muted' if task.completed %>">
                <%= truncate(task.title, length: 50) %>
              </h5>
              <% if task.completed %>
                <span class="badge bg-success">✓</span>
              <% else %>
                <span class="badge bg-warning">Pending</span>
              <% end %>
            </div>
            
            <% if task.description.present? %>
              <p class="card-text text-muted">
                <%= truncate(task.description, length: 100) %>
              </p>
            <% end %>
            
            <small class="text-muted">
              Created <%= time_ago_in_words(task.created_at) %> ago
            </small>
          </div>
          
          <div class="card-footer bg-transparent">
            <div class="btn-group w-100" role="group">
              <%= link_to "View", task_path(task), class: "btn btn-sm btn-outline-primary" %>
              <%= link_to "Edit", edit_task_path(task), class: "btn btn-sm btn-outline-secondary" %>
              <%= button_to "Delete", task_path(task), method: :delete,
                          form: { data: { turbo_confirm: "Are you sure?" } },
                          class: "btn btn-sm btn-outline-danger" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-5">
    <div class="mb-4">
      <i class="fas fa-tasks text-muted" style="font-size: 4rem;"></i>
    </div>
    <h4 class="text-muted">No tasks found</h4>
    <p class="text-muted">
      <% if @filter == 'all' %>
        You haven't created any tasks yet.
      <% elsif @filter == 'pending' %>
        You don't have any pending tasks.
      <% else %>
        You haven't completed any tasks yet.
      <% end %>
    </p>
    <%= link_to "Create your first task", new_task_path, class: "btn btn-success" %>
  </div>
<% end %>