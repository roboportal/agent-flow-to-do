<div class="todo-item <%= 'completed' if @todo.completed %>">
  <h2 class="todo-title <%= 'completed' if @todo.completed %>">
    <%= @todo.title %>
  </h2>
  
  <% if @todo.description.present? %>
    <div class="todo-description">
      <%= simple_format(@todo.description) %>
    </div>
  <% end %>
  
  <div class="todo-meta">
    <p><strong>Status:</strong> <%= @todo.completed? ? 'Completed' : 'Pending' %></p>
    <p><strong>Created:</strong> <%= @todo.created_at.strftime('%B %d, %Y at %I:%M %p') %></p>
    <p><strong>Last Updated:</strong> <%= @todo.updated_at.strftime('%B %d, %Y at %I:%M %p') %></p>
  </div>
</div>

<div style="margin-top: 30px;">
  <%= link_to 'Edit', edit_todo_path(@todo), class: 'btn' %>
  <%= link_to 'Delete', todo_path(@todo), method: :delete,
              confirm: 'Are you sure you want to delete this todo?', class: 'btn btn-danger' %>
  <%= link_to 'Back to All Todos', todos_path, class: 'btn btn-secondary' %>
</div>